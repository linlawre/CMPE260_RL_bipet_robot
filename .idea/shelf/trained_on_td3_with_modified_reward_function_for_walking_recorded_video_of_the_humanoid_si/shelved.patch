+import numpy as np
+from stable_baselines3 import TD3
+from stable_baselines3.common.env_util import make_vec_env
+from stable_baselines3.common.callbacks import BaseCallback, EvalCallback, CallbackList
+from biped_env import BipedalStandBulletEnv
+
+class CurriculumCallback(BaseCallback):
+    def __init__(self, total_timesteps, verbose=0):
+        super().__init__(verbose)
+        self.total_timesteps = total_timesteps
+
+    def _on_step(self) -> bool:
+        # Linearly increase alpha from 0.0 to 1.0 over the course of training
+        current_alpha = self.num_timesteps / self.total_timesteps
+        self.training_env.env_method("set_alpha", current_alpha)
+        return True
+
+if __name__ == "__main__":
+    print("Initializing environments...")
+    # Training environment
+    env = make_vec_env(lambda: BipedalStandBulletEnv(render=False), n_envs=1)
+    
+    # Clean evaluation environment (needed for the EvalCallback)
+    eval_env = make_vec_env(lambda: BipedalStandBulletEnv(render=False), n_envs=1)
+    # Force the eval environment to always test the full walking task (alpha = 1.0)
+    eval_env.env_method("set_alpha", 1.0)
+
+    print("Loading pre-trained standing model...")
+    model = TD3.load("best_model.zip", env=env, tensorboard_log="./td3_walking_tensorboard/")
+
+    total_steps = 1_000_000 
+    
+    # 1. Setup Curriculum Callback
+    curriculum_cb = CurriculumCallback(total_timesteps=total_steps)
+    
+    # 2. Setup Auto-Save (Eval) Callback
+    eval_cb = EvalCallback(
+        eval_env,
+        best_model_save_path="./", # Saves best_model.zip in your current folder
+        eval_freq=10_000,          # Tests the robot every 10,000 steps
+        deterministic=True,
+        render=False
+    )
+    
+    # 3. Combine them into a list
+    all_callbacks = CallbackList([curriculum_cb, eval_cb])
+
+    print("Starting curriculum training for forward locomotion...")
+    # Pass the combined list to the learn function
+    model.learn(total_timesteps=total_steps, callback=all_callbacks)
+
+    print("Training complete! Saving final model...")
+    model.save("final_walking_model")
